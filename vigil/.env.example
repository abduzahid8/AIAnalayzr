# ── Vigil Environment Configuration ──────────────────────────────────
# Copy to .env and fill in real values before running.

# AI/ML inference endpoint (OpenAI-compatible)
AIML_API_KEY=sk-your-aiml-api-key
AIML_BASE_URL=https://api.aimlapi.com/v1
AIML_MODEL=gpt-4o

# Market data – primary source
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key

# Market data – fallback source
FRED_API_KEY=your-fred-api-key

# Redis for state persistence
REDIS_URL=redis://localhost:6379/0

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
