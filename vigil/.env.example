# ── Vigil Environment Configuration ──────────────────────────────────
# Copy to .env and fill in real values before running.

# AI/ML inference endpoint (OpenAI-compatible) — REQUIRED
AIML_API_KEY=your-aiml-api-key
AIML_BASE_URL=https://api.aimlapi.com/v1
AIML_MODEL=gpt-4o

# Market data – primary source
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key

# Market data – optional fallback source (can be blank)
FRED_API_KEY=

# External intelligence sources
NEWSAPI_KEY=your-newsapi-key
REDDIT_ENABLED=true
EDGAR_ENABLED=true

# Redis for state persistence
REDIS_URL=redis://localhost:6379/0
# Optional Vercel/Upstash fallback:
# KV_URL=rediss://default:password@your-host:port

# Frontend clients
PUBLIC_API_BASE_URL=http://127.0.0.1:8000
CORS_ALLOWED_ORIGINS=https://your-web-domain.com
CORS_ALLOW_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1)(:\d+)?$

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
RELOAD=false

# Security — API keys (comma-separated; empty = open access for dev)
API_KEYS=
# Rate limit for /analyse endpoint (requests per minute per IP)
RATE_LIMIT_RPM=10

# Pipeline feature flags
AGENT_VERIFICATION=true
DEBATE_LAYER=true
HISTORY_TTL_DAYS=90
VIGIL_TIER=pro

# Deployment notes:
# - Set REDIS_URL to managed Redis in production (often rediss://...)
# - Set PUBLIC_API_BASE_URL to your public HTTPS API domain
# - Add all frontend domains to CORS_ALLOWED_ORIGINS (comma-separated)
